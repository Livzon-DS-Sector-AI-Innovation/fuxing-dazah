# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-in-production

# Admin
ADMIN_EMPLOYEE_NOS=["111003032"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Feishu SSO — 必填，不设默认值
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_REDIRECT_URI=http://<your-server>/api/v1/identity/auth/callback
FRONTEND_URL=http://<your-server>

# Feishu 组织架构同步
# FEISHU_SYNC_ROOT_DEPT_ID: API POST /sync/departments 触发同步时的根部门
# FEISHU_SYNC_MEMBER_DEPT_ID: 每日 00:00 定时同步成员的目标部门
FEISHU_SYNC_ROOT_DEPT_ID=od-xxx
FEISHU_SYNC_MEMBER_DEPT_ID=od-xxx

# JWT
JWT_EXPIRE_SECONDS=86400

# Audit
AUDIT_RETENTION_DAYS=7

# 安全模块 - 交互机器人（WebSocket 事件订阅）
SAFETY_FEISHU_WS_ENABLED=true
SAFETY_FEISHU_APP_ID=***
SAFETY_FEISHU_APP_SECRET=***

# 安全模块 - 隐患登记多维表格同步
SAFETY_FEISHU_BITABLE_APP_TOKEN  = UKlobrKj3aQ24XsBRkTcqdL0nkc
SAFETY_FEISHU_BITABLE_HAZARD_TABLE_ID = tblB7D5BjNSOruaD

# 安全模块 - AI 模型配置（文本 / 视觉）
SAFETY_AI_TEXT_API_KEY           =
SAFETY_AI_TEXT_BASE_URL          =
SAFETY_AI_TEXT_MODEL             =
SAFETY_AI_VISION_API_KEY         =
SAFETY_AI_VISION_BASE_URL        =
SAFETY_AI_VISION_MODEL           =

# 设备模块 - AI 模型配置
EQUIPMENT_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EQUIPMENT_AI_MODEL=qwen3.7-plus
EQUIPMENT_AI_API_KEY=sk-xxx

# 设备模块 - 维护计划自动生成工单
MAINTENANCE_PLAN_AUTO_ENABLED=true

# 仪表模块 - AI 日期提取配置
METER_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
METER_AI_MODEL=qwen3.6-flash
METER_AI_API_KEY=sk-xxx
METER_CALIBRATION_AUTO_NOTIFY_ENABLED=true

# ──────────────────────────────────────────
# HR 模块 (app/modules/hr)
# ──────────────────────────────────────────

# 能源模块 - 自动采集
ENERGY_AUTO_COLLECT_ENABLED=false

# HR 模块 — 飞书多维表格同步
HR_BITABLE_APP_TOKEN=
HR_BITABLE_EMPLOYEE_TABLE_ID=
HR_BITABLE_DEPARTMENT_TABLE_ID=
HR_BITABLE_OFFBOARDING_TABLE_ID=
HR_BITABLE_ONBOARDING_TABLE_ID=
HR_BITABLE_DEPARTURE_TABLE_ID=
HR_BITABLE_APPROVAL_TABLE_ID=

# HR 模块 — AI 离职分析
HR_AI_API_KEY=
HR_AI_MODEL=deepseek-chat
HR_AI_SYSTEM_PROMPT=你是「小H」，原料药工厂人事管理助手。只基于查询结果回答人事问题，禁止编造。

# MinIO / S3 对象存储（Docker 部署时启用，本地开发可关闭）
MINIO_ENABLED=false
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=dazah
MINIO_SECURE=false

# MCP AI Agent API Keys (comma separated, for service-to-service authentication)
MCP_AGENT_API_KEYS=

# ═══════════════════════════════════════════════════════════
# Logging（集中日志配置）
# ═══════════════════════════════════════════════════════════
# 全局日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 启用指定模块日志（逗号分隔短名，空 = 全部启用）
# 示例：LOG_ENABLED_MODULES=safety,equipment
LOG_ENABLED_MODULES=

# 禁用指定模块日志（逗号分隔短名，空 = 不禁用）
# 仅在 LOG_ENABLED_MODULES 为空时生效
# 示例：LOG_DISABLED_MODULES=energy,hr
LOG_DISABLED_MODULES=

# 三方库统一日志级别（可被细粒度 LOG_<LIB>_LEVEL 覆盖）
# 优先级：LOG_SQLALCHEMY_LEVEL > LOG_THIRD_PARTY_LEVEL > 内置默认值
LOG_THIRD_PARTY_LEVEL=WARNING

# 三方库 handler 级过滤阈值（防止库内部 setLevel 绕过）
# 仅影响控制台输出，低于此级别的三方库日志不会进入 stdout
LOG_THIRD_PARTY_HANDLER_LEVEL=WARNING

# root logger 兜底级别（仅影响未被上述 logger 覆盖的日志）
LOG_ROOT_LEVEL=WARNING

# 生产环境日志文件目录（仅 APP_ENV=production 时写入）
LOG_DIR=logs
