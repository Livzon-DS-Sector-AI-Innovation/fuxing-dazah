# ═══════════════════════════════════════════════════
# 生产环境配置文件模板
# 使用方法：cp .env.production.template .env.production 然后修改实际值
# ⚠️ .env.production 不能提交到 Git！
# ═══════════════════════════════════════════════════

# ── 基础配置 ──
APP_NAME=dazah-backend
APP_ENV=production
DEBUG=false
SECRET_KEY=<替换为随机生成的64位密钥>

# ── 管理员 ──
ADMIN_EMPLOYEE_NOS=["<管理员工号>"]

# ── 数据库（生产环境） ──
# Docker Compose: postgresql+asyncpg://postgres:postgres@db:5432/dazah
# 独立部署: postgresql+asyncpg://<user>:<password>@<host>:5432/<dbname>
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<dbname>
POSTGRES_USER=<db_user>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=dazah
DB_PORT=5432

# ── Redis ──
# Docker Compose: redis://redis:6379/0
# 独立部署: redis://<host>:6379/0
REDIS_URL=redis://<host>:6379/0
REDIS_PORT=6379

# ── JWT ──
JWT_EXPIRE_SECONDS=86400

# ── 审计日志保留天数 ──
AUDIT_RETENTION_DAYS=30

# ── 飞书 SSO ──
FEISHU_APP_ID=<飞书应用AppID>
FEISHU_APP_SECRET=<飞书应用Secret>
FEISHU_REDIRECT_URI=http://<服务器IP或域名>/api/v1/identity/auth/callback
FRONTEND_URL=http://<服务器IP或域名>:3000
FEISHU_SYNC_ROOT_DEPT_ID=<飞书根部门ID>
FEISHU_SYNC_MEMBER_DEPT_ID=<飞书成员部门ID>

# ── HR 模块 — AI 出题 ──
HR_AI_API_KEY=<DeepSeek API Key>

# ── HR 模块 — 飞书多维表格同步 ──
HR_BITABLE_APP_TOKEN=<Bitable App Token>
HR_BITABLE_EMPLOYEE_TABLE_ID=<员工表ID>
