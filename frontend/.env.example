# ============================================
# 本地开发
# ============================================
# 后端 API 地址（FastAPI 服务）
# 客户端代码用 LAN IP，让局域网内其他电脑也能访问
# NEXT_PUBLIC_API_BASE_URL=http://192.168.3.100:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# 服务端代码（Server Actions）跑在本机，可以用 localhost
API_BASE_URL=http://localhost:8000

# ============================================
# Docker 部署
# ============================================
# 1. 从 .env.production.example 复制一份 .env.production
# 2. 把地址改成服务器真实 IP
# 3. 直接构建，不用传 --build-arg：
#
#    docker build -t dazah-frontend .
#
# 4. 运行：
#
#    docker run -d -p 3000:3000 --name dazah-frontend dazah-frontend
