# App
APP_NAME=dazah-backend
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dazah
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dazah
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Feishu SSO — 必填，不设默认值
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_REDIRECT_URI=http://<your-server>/api/v1/identity/auth/callback
FRONTEND_URL=http://<your-server>

# Feishu 组织架构同步
# FEISHU_SYNC_ROOT_DEPT_ID: API POST /sync/departments 触发同步时的根部门
# FEISHU_SYNC_MEMBER_DEPT_ID: 每日 00:00 定时同步成员的目标部门
FEISHU_SYNC_ROOT_DEPT_ID=od-xxx
FEISHU_SYNC_MEMBER_DEPT_ID=od-xxx

# JWT
JWT_EXPIRE_SECONDS=86400

# Audit
AUDIT_RETENTION_DAYS=7

# 安全模块 - 机器人
SAFETY_FEISHU_APP_ID=***
SAFETY_FEISHU_APP_SECRET=***

# 设备模块 - 交互机器人
EQUIPMENT_FEISHU_WS_ENABLED=false
EQUIPMENT_FEISHU_APP_ID=***
EQUIPMENT_FEISHU_APP_SECRET=***

# 设备模块 - 维护计划自动生成工单
MAINTENANCE_PLAN_AUTO_ENABLED=true

# HR 模块 — 飞书多维表格同步
FEISHU_BOT_NAME=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_EMPLOYEE_TABLE_ID=
FEISHU_BITABLE_DEPARTMENT_TABLE_ID=
FEISHU_BITABLE_OFFBOARDING_TABLE_ID=
FEISHU_BITABLE_ONBOARDING_TABLE_ID=
FEISHU_BITABLE_DEPARTURE_TABLE_ID=
FEISHU_BITABLE_APPROVAL_TABLE_ID=

# HR 模块 — 培训通知多维表格
FEISHU_BITABLE_TRAINING_NOTIFICATION_APP_TOKEN=
FEISHU_BITABLE_TRAINING_NOTIFICATION_TABLE_ID=

# HR 模块 — AI 离职分析（Moonshot/Kimi API）
MOONSHOT_API_KEY=
AI_MODEL=kimi-k2.5
